# ==========================================
# GEMINI-CLAUDE BRIDGE CONFIGURATION
# ==========================================

# 1. YOUR API KEY: Get this from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY="your_api_key_here"

# 2. DEFAULT MODEL: The Gemini model to use as a backend
# Recommended: "gemini-2.0-flash" or "gemini-1.5-flash"
MODEL="gemini-2.0-flash"

# 3. SECURITY TOKEN: Optional token to protect your bridge
# If set, you must use it in Claude Code: export ANTHROPIC_API_KEY=your_token
ANTHROPIC_AUTH_TOKEN="freecc"

# ==========================================
# PERFORMANCE & BEHAVIOR
# ==========================================

# Enable experimental thinking/reasoning blocks for supported models
ENABLE_THINKING=true

# Server Configuration
HOST="0.0.0.0"
PORT=8082
LOG_FILE="server.log"
